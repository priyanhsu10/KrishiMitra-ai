<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Crop Details"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/et_crop_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Crop Type (e.g., Soybean, Cotton)"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/et_sowing_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Sowing Date (YYYY-MM-DD)"
        android:inputType="date"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/et_stage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Current Stage (e.g., growing)"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_save_crop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Finish Registration"/>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"/>

</LinearLayout>