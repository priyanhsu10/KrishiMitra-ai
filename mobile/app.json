{
  "expo": {
    "name": "KrishiMitra",
    "slug": "krishimitra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2E7D32"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.krishimitra.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2E7D32"
      },
      "package": "com.krishimitra.app",
      "googleServicesFile": "./android/app/google-services.json"
    },
    "plugins": [
      "expo-image-picker",
      "expo-location"
    ]
  }
}
